# Required for real voice cloning (https://elevenlabs.io)
ELEVENLABS_API_KEY=

# Optional — defaults shown
PORT=8787
HOST=127.0.0.1
# Comma-separated origins (GitHub Pages, localhost, etc.)
CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# Where cached MP3s and metadata are stored
DATA_DIR=./data

# ElevenLabs model for narration
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Provider: elevenlabs | xtts | mock
VOICE_PROVIDER=xtts

# Local Coqui XTTS sidecar (see xtts-service/README.md)
XTTS_SERVICE_URL=http://127.0.0.1:5002
XTTS_LANGUAGE=en
# Bedtime story synth — slower & warmer for toddlers (0.85–0.92 typical)
XTTS_STORY_SPEED=0.88
XTTS_STORY_TEMPERATURE=0.72
STORY_AUDIO_STYLE=bedtime-v1
